{
  "name": "wordpress-psr/request-handler",
  "type": "library",
  "description": "A PSR-15 server request handler for WordPress.",
  "keywords": [
    "middleware",
    "psr-7",
    "psr-15",
    "WordPress"
  ],
  "homepage": "https://github.com/WordPress-PSR/request-handler",
  "license": "MIT",
  "authors": [
    {
      "name": "David Stone",
      "homepage": "https://github.com/superdav42",
      "email": "david@stonefamily.ro"
    }
  ],
  "require": {
    "php": ">=8.1",
    "dflydev/fig-cookies": "^3.0",
    "johnpbloch/wordpress-core": ">=6.0",
    "johnpbloch/wordpress-core-installer": "^2.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.0 || ^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "rector/rector": "^2.0"
  },
  "require-dev": {
    "laminas/laminas-diactoros": "^3.0",
    "laminas/laminas-httphandlerrunner": "^2.0",
    "nyholm/psr7": "^1.8",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.0 || ^11.0",
    "roave/security-advisories": "dev-master",
    "squizlabs/php_codesniffer": "^3.0",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "suggest": {
    "nyholm/psr7": "Lightweight PSR-7/PSR-17 implementation."
  },
  "autoload": {
    "psr-4": {
      "WordPressPsr\\": "src/"
    },
    "files": [
      "src/wp-functions.php",
      "src/pluggable-functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "WordPressPsr\\Tests\\": "tests/"
    }
  },
  "replace": {
    "superdav42/wordpress-core": "*"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "johnpbloch/wordpress-core-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "provide": {
    "psr/http-server-handler-implementation": "1.0"
  },
  "scripts": {
    "post-install-cmd": [
      "@rector-transform"
    ],
    "post-update-cmd": [
      "@rector-transform"
    ],
    "rector-transform": [
      "Composer\\Config::disableProcessTimeout",
      "rector process --config rector.php --no-progress-bar"
    ],
    "test": [
      "phpunit"
    ],
    "test:lint": [
      "phpcs --standard=phpcs.xml src/",
      "phpstan analyse"
    ],
    "fix": [
      "phpcbf --standard=phpcs.xml src/"
    ]
  }
}
